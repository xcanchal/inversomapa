---
import Base from "../../layouts/Base.astro";
import Graph from "../../components/Graph.jsx";
import ViewTabs from "../../components/ViewTabs.astro";
import { UI, rootInfo, withBase } from "../../data/taxonomy.js";

export function getStaticPaths() {
  return [{ params: { locale: "ca" } }, { params: { locale: "es" } }];
}
const { locale } = Astro.params;
const other = locale === "ca" ? "es" : "ca";
const root = rootInfo(locale);
const base = import.meta.env.BASE_URL;
---
<Base
  locale={locale}
  title={UI.title[locale]}
  description={root.desc}
  altPath={`/${other}/`}
>
  <main class="layout">
    <div class="graph-pane">
      <ViewTabs locale={locale} active="products" />
      <Graph client:load locale={locale} view="products" selectedSlug={null} />
      <div class="graph-tip">{UI.tip[locale]}</div>
    </div>
    <aside class="panel">
      <h1 class="serif">{root.label}</h1>
      <p>{root.desc}</p>
      <div class="section-label">{UI.inCategory[locale]}</div>
      <div>
        {root.children.map((c) => (
          <a class="chip" href={withBase(`/${locale}/guia/${c.slug}/`, base)}>{c.label}</a>
        ))}
      </div>
    </aside>
  </main>
</Base>
