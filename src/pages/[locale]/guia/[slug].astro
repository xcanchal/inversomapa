---
import Base from "../../../layouts/Base.astro";
import Graph from "../../../components/Graph.jsx";
import ViewTabs from "../../../components/ViewTabs.astro";
import { UI, flatten, withBase } from "../../../data/taxonomy.js";

export function getStaticPaths() {
  return ["ca", "es"].flatMap((locale) =>
    flatten(locale).map((node) => ({
      params: { locale, slug: node.slug },
      props: { node },
    }))
  );
}

const { locale } = Astro.params;
const { node } = Astro.props;
const other = locale === "ca" ? "es" : "ca";
const altPath = `/${other}/guia/${node.altSlug}/`;
const base = import.meta.env.BASE_URL;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    ...node.breadcrumb.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.label,
      item: new URL(withBase(b.href, base), Astro.site).href,
    })),
    {
      "@type": "ListItem",
      position: node.breadcrumb.length + 1,
      name: node.label,
      item: new URL(Astro.url.pathname, Astro.site).href,
    },
  ],
};
---
<Base
  locale={locale}
  title={`${node.label} — ${UI.title[locale]}`}
  description={node.desc}
  altPath={altPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <main class="layout">
    <div class="graph-pane">
      <ViewTabs locale={locale} active={node.view} />
      <Graph client:load locale={locale} view={node.view} selectedSlug={node.slug}
        inlineDetails={node.view === "horizon"} />
    </div>
    <aside class="panel" data-inline-details={node.view === "horizon" ? true : undefined}>
      <nav class="breadcrumb" aria-label="Breadcrumb" data-panel-breadcrumb>
        {node.breadcrumb.map((b) => (
          <span><a href={withBase(b.href, base)}>{b.label}</a>{"  →  "}</span>
        ))}
      </nav>
      <h1 class="serif" data-panel-title>{node.label}</h1>
      <div class="sub" data-panel-sub hidden={!node.sub}>{node.sub}</div>
      <p data-panel-description>{node.desc}</p>
      <div data-panel-children hidden={node.children.length === 0}>
          <div class="section-label">{UI.inCategory[locale]}</div>
          <div>
            {node.children.map((c) => (
              <a class="chip" href={withBase(`/${locale}/guia/${c.slug}/`, base)}>{c.label}</a>
            ))}
          </div>
      </div>
    </aside>
  </main>
  <script>
    const panel = document.querySelector("[data-inline-details]");
    if (panel) window.addEventListener("graph-node-select", (event) => {
      const { label, sub, desc } = event.detail;
      panel.querySelector("[data-panel-title]").textContent = label;
      const subtitle = panel.querySelector("[data-panel-sub]");
      subtitle.textContent = sub || "";
      subtitle.hidden = !sub;
      panel.querySelector("[data-panel-description]").textContent = desc || "";
      panel.querySelector("[data-panel-breadcrumb]").hidden = true;
      panel.querySelector("[data-panel-children]").hidden = true;
    });
  </script>
</Base>
