---
import Base from "../../../layouts/Base.astro";
import Graph from "../../../components/Graph.jsx";
import ViewTabs from "../../../components/ViewTabs.astro";
import { UI, rootInfo, withBase } from "../../../data/taxonomy.js";

/** Root of the horizon view. Its slug is localised, hence the dynamic segment. */
export function getStaticPaths() {
  return ["ca", "es"].map((locale) => ({
    params: { locale, view: rootInfo(locale, "horizon").slug },
  }));
}

const { locale } = Astro.params;
const other = locale === "ca" ? "es" : "ca";
const root = rootInfo(locale, "horizon");
const altPath = `/${other}/${rootInfo(other, "horizon").slug}/`;
const base = import.meta.env.BASE_URL;
---
<Base
  locale={locale}
  title={`${root.label} — ${UI.title[locale]}`}
  description={root.desc}
  altPath={altPath}
>
  <main class="layout">
    <div class="graph-pane">
      <ViewTabs locale={locale} active="horizon" />
      <Graph client:load locale={locale} view="horizon" selectedSlug={null} />
      <div class="graph-tip">{UI.tip[locale]}</div>
    </div>
    <aside class="panel">
      <h1 class="serif">{root.label}</h1>
      <p>{root.desc}</p>
      <div class="section-label">{UI.inCategory[locale]}</div>
      <div>
        {root.children.map((c) => (
          <a class="chip" href={withBase(`/${locale}/guia/${c.slug}/`, base)}>{c.label}</a>
        ))}
      </div>
    </aside>
  </main>
</Base>
