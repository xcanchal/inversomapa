---
import Base from "../../../layouts/Base.astro";
import Graph from "../../../components/Graph.jsx";
import ViewTabs from "../../../components/ViewTabs.astro";
import { UI, rootInfo, withBase } from "../../../data/taxonomy.js";

/** Root of the horizon view. Its slug is localised, hence the dynamic segment. */
export function getStaticPaths() {
  return ["ca", "es"].map((locale) => ({
    params: { locale, view: rootInfo(locale, "horizon").slug },
  }));
}

const { locale } = Astro.params;
const other = locale === "ca" ? "es" : "ca";
const root = rootInfo(locale, "horizon");
const altPath = `/${other}/${rootInfo(other, "horizon").slug}/`;
const base = import.meta.env.BASE_URL;
---
<Base
  locale={locale}
  title={`${root.label} — ${UI.title[locale]}`}
  description={root.desc}
  altPath={altPath}
>
  <main class="layout">
    <div class="graph-pane">
      <ViewTabs locale={locale} active="horizon" />
      <Graph client:load locale={locale} view="horizon" selectedSlug={null} inlineDetails />
      <div class="graph-tip">{UI.tip[locale]}</div>
    </div>
    <aside class="panel" data-inline-details>
      <h1 class="serif" data-panel-title>{root.label}</h1>
      <div class="sub" data-panel-sub hidden={!root.sub}>{root.sub}</div>
      <p data-panel-description>{root.desc}</p>
      <div data-panel-children>
        <div class="section-label">{UI.inCategory[locale]}</div>
        <div>
        {root.children.map((c) => (
          <a class="chip" href={withBase(`/${locale}/guia/${c.slug}/`, base)}>{c.label}</a>
        ))}
        </div>
      </div>
    </aside>
  </main>
  <script>
    const panel = document.querySelector("[data-inline-details]");
    if (panel) window.addEventListener("graph-node-select", (event) => {
      const { label, sub, desc } = event.detail;
      panel.querySelector("[data-panel-title]").textContent = label;
      const subtitle = panel.querySelector("[data-panel-sub]");
      subtitle.textContent = sub || "";
      subtitle.hidden = !sub;
      panel.querySelector("[data-panel-description]").textContent = desc || "";
      panel.querySelector("[data-panel-children]").hidden = true;
    });
  </script>
</Base>
